---
interface LogoCell {
  name: string;
  logo?: string;
  caseStudy?: string;
}

interface Props {
  label?: string;
  logos?: LogoCell[];
}

const {
  label = "Trusted by over 100 GTM teams",
  logos = [
    { name: "Scrypt", logo: "/logos/scrypt.webp", caseStudy: "/case-studies/scrypt" },
    { name: "HubSpot", logo: "/logos/hubspot.png" },
    { name: "Skribble", logo: "/logos/skribble.webp" },
    { name: "Strategyzer", logo: "/logos/strategyzer.jpg" },
    { name: "Ohalo", logo: "/logos/ohalo.webp", caseStudy: "/case-studies/ohalo" },
    { name: "Bound", logo: "/logos/bound.avif" },
    { name: "Hy.co", logo: "/logos/hyco.png" },
    { name: "Lipdub", logo: "/logos/lipdub.avif" },
    { name: "Adthena", logo: "/logos/adthena.png" },
    { name: "Emlen", logo: "/logos/emlen.svg" },
    { name: "Leostream", logo: "/logos/leostream.webp" },
    { name: "Orca", logo: "/logos/orca.png" },
    { name: "Mybites", logo: "/logos/mybites.svg" },
    { name: "Sysdyne", logo: "/logos/sysdyne.png" },
    { name: "Trawa", logo: "/logos/trawa.png" },
    { name: "Blueprint", logo: "/logos/blueprint.png" },
  ],
} = Astro.props;

// Split into two lanes (linked/case-study logos to lane 1, rest to lane 2)
const linked = logos.filter((l) => l.caseStudy);
const others = logos.filter((l) => !l.caseStudy);
const lane1 = [...linked, ...others.slice(0, Math.ceil(others.length / 2) - linked.length)];
const lane2 = others.slice(lane1.length - linked.length);

// Fallback in case the split is uneven
const finalLane1 = lane1.length ? lane1 : logos.slice(0, Math.ceil(logos.length / 2));
const finalLane2 = lane2.length ? lane2 : logos.slice(Math.ceil(logos.length / 2));

const track1 = [...finalLane1, ...finalLane1];
const track2 = [...finalLane2, ...finalLane2];

function renderInner(logo: LogoCell) {
  return logo.logo
    ? `<img class="logo-img" src="${logo.logo}" alt="${logo.name}" loading="lazy" />`
    : `<span class="logo-mark">${logo.name}</span>`;
}
---

<section class="marquee-section" aria-label="Clients">
  <div class="marquee-row">
    <div class="marquee-label">{label}</div>
    <div class="marquee-lanes">
      <!-- Lane 1 — scrolls left -->
      <div class="marquee">
        <div class="marquee-track">
          {
            track1.map((logo, idx) => (
              logo.caseStudy ? (
                <a
                  class="marquee-cell has-link"
                  href={logo.caseStudy}
                  aria-hidden={idx >= finalLane1.length}
                >
                  {logo.logo ? (
                    <img
                      class="logo-img"
                      src={logo.logo}
                      alt={logo.name}
                      loading="lazy"
                    />
                  ) : (
                    <span class="logo-mark">{logo.name}</span>
                  )}
                  <span class="cs-pill">Case Study</span>
                </a>
              ) : (
                <span class="marquee-cell" aria-hidden={idx >= finalLane1.length}>
                  {logo.logo ? (
                    <img
                      class="logo-img"
                      src={logo.logo}
                      alt={logo.name}
                      loading="lazy"
                    />
                  ) : (
                    <span class="logo-mark">{logo.name}</span>
                  )}
                </span>
              )
            ))
          }
        </div>
      </div>

      <!-- Lane 2 — scrolls right (reverse) -->
      <div class="marquee reverse">
        <div class="marquee-track">
          {
            track2.map((logo, idx) => (
              logo.caseStudy ? (
                <a
                  class="marquee-cell has-link"
                  href={logo.caseStudy}
                  aria-hidden={idx >= finalLane2.length}
                >
                  {logo.logo ? (
                    <img
                      class="logo-img"
                      src={logo.logo}
                      alt={logo.name}
                      loading="lazy"
                    />
                  ) : (
                    <span class="logo-mark">{logo.name}</span>
                  )}
                  <span class="cs-pill">Case Study</span>
                </a>
              ) : (
                <span class="marquee-cell" aria-hidden={idx >= finalLane2.length}>
                  {logo.logo ? (
                    <img
                      class="logo-img"
                      src={logo.logo}
                      alt={logo.name}
                      loading="lazy"
                    />
                  ) : (
                    <span class="logo-mark">{logo.name}</span>
                  )}
                </span>
              )
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>