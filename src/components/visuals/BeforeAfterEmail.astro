---
// Before/After email visual for Block 3 (Outbound).
// Authored at 900×875 in Claude Design; the .ev-stage-fit wrapper auto-scales.
// Scoped under .ev-root with ev-* class prefix so no collision with site CSS.
---

<div class="ev-root">
  <div class="ev-stage-fit">
    <div class="ev-stage" role="img" aria-label="Before and after email outreach comparison">
      <!-- Before label -->
      <span class="ev-label ev-label-before">Before</span>

      <!-- Before panel: templated email skeleton -->
      <div class="ev-panel ev-panel-before">
        <div class="ev-tpl">
          <div>Hi <span class="ev-chip">First name</span></div>
          <div style="margin-top: 14px;">
            Saw that you <span class="ev-chip">intent signal</span> Specifically, you <span class="ev-chip">AI Summary</span>
          </div>
          <div>
            <span class="ev-chip">Datapoint</span> usually <span class="ev-chip">AI inferred problem</span>
          </div>
          <div>We solve this by <span class="ev-chip">AI personalized value proposition</span></div>
          <div style="margin-top: 10px;">Wo</div>
          <div>Be</div>
          <div>Se</div>
        </div>
      </div>

      <!-- After label with sparkle -->
      <span class="ev-label ev-label-after">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3z" />
          <path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14z" />
        </svg>
        After
      </span>

      <!-- After panel: composed email -->
      <div class="ev-panel ev-panel-after">
        <div class="ev-email-head">
          <div class="ev-avatar" aria-hidden="true">
            <img src="/team/lanny.png" alt="Lanny Heiz" />
          </div>
          <div class="ev-from">
            <div class="ev-name">Lanny Heiz</div>
            <div class="ev-addr">lanny@enablement.ch</div>
          </div>
          <div class="ev-time">9:14&nbsp;AM <span class="ev-time-rel">(8 hours ago)</span></div>
        </div>

        <div class="ev-body">
          <p>Hi Hugh,</p>
          <p>
            Saw that you're hiring a marketing specialist. In the ad you
            <span class="ev-hl">mentioned improving conversion rates for your online store</span>
            is key.
          </p>
          <p>
            Ahrefs estimates your traffic at around 81'000 visitors and on Shopify around
            <span class="ev-hl">10% of shoppers abandon their carts</span>.
          </p>
          <p>
            Usually, the AOV of a store like yours is around $75, this means you're missing
            <span class="ev-hl">about $15'000 in revenue every month.</span>
          </p>
          <p>We solve this by helping online stores identify their shoppers and retarget them without spending $ on ads.</p>
          <p>Can I send you the last 100 customers you missed for free?</p>
        </div>
      </div>

      <!-- Blue AI action pills -->
      <span class="ev-ai ev-ai-find">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7" />
          <path d="M21 21l-4.3-4.3" />
        </svg>
        Find any datapoint
      </span>
      <span class="ev-ai ev-ai-summarise">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3z" />
        </svg>
        Summarise with AI
      </span>
      <span class="ev-ai ev-ai-write">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3z" />
        </svg>
        Write AI personalisations
      </span>
    </div>
  </div>
</div>

<style>
  /* ── Scoped tokens — light mode ─────────────────────── */
  .ev-root {
    --ev-canvas: #F2F4F8;
    --ev-surface: #FFFFFF;
    --ev-border: #E1E5EC;
    --ev-border-2: #C9CFD9;
    --ev-ink: #0F1217;
    --ev-muted: #7C8390;
    --ev-accent: #E11E48;
    --ev-on-accent: #FFFFFF;
    --ev-blue: #2F86E8;
    --ev-flow: #6FA8DC;

    /* Minimum width so .ev-root doesn't collapse to 0 inside our flex .pain-visual
       container (since all its descendants are absolute-positioned). Horizontal
       padding keeps the Find pill (which sits at x:0 in stage coords) off the
       .pain-visual frame border. */
    width: 100%;
    margin: 0 auto;
    padding: 0 10px;
    box-sizing: border-box;

    font-family: "Sofia Sans", system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Dark mode token overrides ──────────────────────── */
  :global([data-theme="dark"]) .ev-root {
    --ev-canvas: #181C23;
    --ev-surface: #232830;
    --ev-border: #2E343F;
    --ev-border-2: #404754;
    --ev-ink: #E5E9F0;
    --ev-muted: #6B7280;
  }

  /* ── Scale-to-fit wrapper ──────────────────────────────
     Stage shifted right by 70px so the visual content (which is biased toward
     the left of the 900px canvas) appears horizontally centered in the frame. */
  .ev-stage-fit {
    position: relative;
    width: 100%;
    aspect-ratio: 900 / 875;
    margin: 0 auto;
  }
  .ev-stage {
    position: absolute;
    top: 0;
    left: 55px;
    width: 900px;
    aspect-ratio: 900 / 875;
    transform-origin: top left;
  }

  /* ── Before / After crimson pills ────────────────────── */
  .ev-label {
    position: absolute;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--ev-accent);
    color: var(--ev-on-accent);
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    border-radius: 8px;
    letter-spacing: -0.005em;
    box-shadow: 0 4px 12px rgba(15, 18, 23, 0.06);
  }
  .ev-label svg {
    width: 14px;
    height: 14px;
  }
  .ev-label-before {
    top: 100px;
    left: 104px;
  }
  .ev-label-after {
    top: 296px;
    right: 208px;
    padding-left: 12px;
  }

  /* ── Cards ───────────────────────────────────────────── */
  .ev-panel {
    position: absolute;
    background: var(--ev-surface);
    border: 1px solid var(--ev-border);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(15, 18, 23, 0.08);
    padding: 24px 32px 32px;
    z-index: 2;
  }
  .ev-panel-before {
    top: 116px;
    left: 88px;
    width: 460px;
    z-index: 2;
  }
  .ev-panel-after {
    top: 312px;
    left: 144px;
    width: 506px;
    z-index: 4;
  }

  /* ── Before template (skeleton with chips) ───────────── */
  .ev-tpl {
    color: var(--ev-ink);
    font-size: 16px;
    line-height: 2.05;
    letter-spacing: -0.005em;
  }
  .ev-tpl > div {
    margin: 2px 0;
  }
  .ev-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    margin: 0 2px;
    background: var(--ev-canvas);
    color: var(--ev-ink);
    border: 1px solid var(--ev-border-2);
    border-radius: 8px;
    font-weight: 500;
    font-size: 14.5px;
    line-height: 1.25;
    white-space: nowrap;
  }

  /* ── After email ─────────────────────────────────────── */
  .ev-email-head {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 12px;
    align-items: center;
    margin-bottom: 24px;
  }
  .ev-avatar {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    overflow: hidden;
    background: var(--ev-accent);
  }
  .ev-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ev-from .ev-name {
    color: var(--ev-accent);
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .ev-from .ev-addr {
    color: var(--ev-muted);
    font-size: 14px;
    line-height: 1.35;
  }
  .ev-time {
    color: var(--ev-muted);
    font-size: 13.5px;
    white-space: nowrap;
    align-self: start;
    padding-top: 4px;
  }
  .ev-time .ev-time-rel {
    color: var(--ev-muted);
  }

  .ev-body {
    color: var(--ev-ink);
    font-size: 15.5px;
    line-height: 1.7;
    letter-spacing: -0.003em;
  }
  .ev-body p {
    margin: 0 0 16px;
    max-width: none;
  }
  .ev-body p:last-child {
    margin-bottom: 0;
  }

  .ev-hl {
    background: color-mix(in srgb, var(--ev-flow) 22%, var(--ev-surface));
    border-radius: 4px;
    padding: 1px 4px;
    margin: 0 -1px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  /* ── Blue AI action pills ────────────────────────────── */
  .ev-ai {
    position: absolute;
    z-index: 6;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px 9px 12px;
    background: var(--ev-blue);
    color: #ffffff;
    font-weight: 600;
    font-size: 14.5px;
    line-height: 1;
    border-radius: 999px;
    letter-spacing: -0.005em;
    box-shadow:
      0 4px 12px rgba(47, 134, 232, 0.3),
      0 1px 2px rgba(15, 18, 23, 0.08);
    white-space: nowrap;
  }
  .ev-ai svg {
    width: 16px;
    height: 16px;
  }
  .ev-ai-find {
    top: 488px;
    left: 0px;
  }
  .ev-ai-summarise {
    top: 470px;
    left: 592px;
  }
  .ev-ai-write {
    top: 608px;
    left: 563px;
  }
</style>

<script is:inline>
  (function () {
    var fits = document.querySelectorAll(".ev-stage-fit");
    function apply() {
      fits.forEach(function (fit) {
        var stage = fit.querySelector(".ev-stage");
        if (!stage) return;
        var avail = fit.getBoundingClientRect().width;
        stage.style.transform = "scale(" + Math.min(1, avail / 900) + ")";
      });
    }
    apply();
    window.addEventListener("resize", apply);
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(apply);
  })();
</script>